API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
HF_TOKEN=api_key


# Choose which task to run
# Available options:
# easy_001   → basic dependency + logs
# easy_002   → memory / OOM issue
# easy_003   → latency / timeout issue
# medium_001 → multi-service cascade debugging
# hard_001   → complex multi-root reasoning scenario

TASK_ID=easy_001
SEED=42